# OpenAI credentials
OPENAI_API_KEY=sk-...

# Application mode: development | testing | production
APP_ENV=development

# Database URL. Defaults to local SQLite if not provided.
# For Docker Compose use: postgresql+asyncpg://postgres:postgres@postgres:5432/quizdb
DATABASE_URL=sqlite+aiosqlite:///./quiz_local.db

# Redis URL. Leave empty to use an in-memory fallback locally.
# For Docker Compose use: redis://redis:6379/0
REDIS_URL=

# LLM configuration
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# History window for memory injection
HISTORY_WINDOW_SIZE=10
